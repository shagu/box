#!/bin/bash
# /usr/bin/box - universal sandbox wrapper

REAL_PWD="$(realpath .)"
BOX_RC="$HOME/.boxrc"
BOX_USER="$(whoami)"

# create a safe temporary passwd file for the sandbox
PASSWD_TMP="/tmp/box_passwd_$BOX_USER"
if [ -f /etc/passwd ]; then
  # replace any potential weird home paths for your user back to the standard one
  sed "s|^${BOX_USER}:\(.*\):[^:]*$|${BOX_USER}:\1:${HOME}|" /etc/passwd > "$PASSWD_TMP"
else
  echo "${BOX_USER}:x:$(id -u):$(id -g)::/home/${BOX_USER}:/bin/bash" > "$PASSWD_TMP"
fi

BWRAP_ARGS=(
  --ro-bind / /
  --dev /dev
  --proc /proc
  --tmpfs /tmp
  --tmpfs /run
  --share-net
  # overwrite the passwd file with our corrected version
  --ro-bind "$PASSWD_TMP" /etc/passwd
  # hide the real home by mounting a fresh tmpfs directly over it
  --tmpfs "$HOME"
  --bind "$REAL_PWD" "$REAL_PWD"
  --chdir "$REAL_PWD"
  --setenv HOME "$HOME"
)

# parse custom mounts from ~/.boxrc
if [ -f "$BOX_RC" ]; then
  while IFS= read -r host_path || [ -n "$host_path" ]; do
    [[ "$host_path" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${host_path// }" ]] && continue

    # expand tilde to host home path
    host_path="${host_path/#\~/$HOME}"

    if [ -e "$host_path" ]; then
      # create parent directories inline if missing in the new tmpfs home
      BWRAP_ARGS+=(--dir "$(dirname "$host_path")")
      BWRAP_ARGS+=(--bind "$host_path" "$host_path")
    fi
  done < "$BOX_RC"
fi

[ $# -eq 0 ] && set -- bash

# execute sandbox and clear the temp file afterwards automatically
exec bwrap "${BWRAP_ARGS[@]}" "$@"
